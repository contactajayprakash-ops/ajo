{
  "id": "ajo-sign-in-01",
  "resource": "sign-in",
  "tokenize": {
    "type": "JWT",
    "algorithm": "HS256",
    "expiration": 604800,
    "encryption_key": "$ENV.JWT_SECRET_KEY",
    "custom_claim_fields": ["id", "email", "name"],
    "property_name": "token"
  },
  "actionables": [
    {
      "id": 1,
      "mode": "QUERY",
      "payload_validation": [
        {
          "field": { "email": { "type": "EMAIL" } },
          "max_length": 255
        },
        {
          "field": { "password": { "type": "STRING" } },
          "min_length": 8,
          "max_length": 255
        }
      ],
      "sql_query": {
        "query": "SELECT id, name, email, password FROM users WHERE email = $1 AND deleted_at IS NULL",
        "parameters": ["email"]
      },
      "verify_hashables": [
        {
          "property": "password",
          "algorithm": "BCRYPT"
        }
      ],
      "returnables": ["id", "name", "email", "token"]
    }
  ]
}
