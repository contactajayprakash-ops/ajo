{
  "id": "ajo-contribute-01",
  "resource": "contribute",
  "tokenize": {
    "type": "JWT",
    "algorithm": "HS256",
    "encryption_key": "$ENV.JWT_SECRET_KEY"
  },
  "protected": {
    "provide_as": "x-access-token",
    "extract_claims": ["id", "name"]
  },
  "actionables": [
    {
      "id": 1,
      "mode": "QUERY",
      "payload_validation": [
        { "field": { "circle_id": { "type": "STRING" } }, "min_length": 4, "max_length": 255 }
      ],
      "sql_query": {
        "query": "SELECT contribution_amount, current_cycle FROM circles WHERE id = $1 AND status = 'active' AND deleted_at IS NULL",
        "parameters": ["$PAYLOAD.circle_id"]
      },
      "must_return_value": true,
      "returnables": ["contribution_amount", "current_cycle"]
    },
    {
      "id": 2,
      "mode": "QUERY",
      "depends_on": [
        {
          "resource_id": "self",
          "action_ids": [1],
          "extract_response_for": [
            { "extract": "contribution_amount", "for": "amt" },
            { "extract": "current_cycle", "for": "cyc" }
          ]
        }
      ],
      "sql_query": {
        "query": "INSERT INTO contributions (id, circle_id, user_id, cycle, amount, created_at) VALUES ($1, $2, $3, $4::int, $5::float8, $6::timestamptz)",
        "parameters": ["$GENERATOR.KSUID", "$PAYLOAD.circle_id", "$PROTECTED.id", "cyc", "amt", "$DATETIME"]
      }
    },
    {
      "id": 3,
      "mode": "QUERY",
      "depends_on": [
        {
          "resource_id": "self",
          "action_ids": [1],
          "extract_response_for": [{ "extract": "contribution_amount", "for": "amt" }]
        }
      ],
      "sql_query": {
        "query": "UPDATE circles SET pot_balance = pot_balance + $1::float8, updated_at = $2::timestamptz WHERE id = $3",
        "parameters": ["amt", "$DATETIME", "$PAYLOAD.circle_id"]
      }
    },
    {
      "id": 4,
      "mode": "QUERY",
      "depends_on": [
        {
          "resource_id": "self",
          "action_ids": [1],
          "extract_response_for": [{ "extract": "contribution_amount", "for": "amt" }]
        }
      ],
      "sql_query": {
        "query": "INSERT INTO activities (id, circle_id, user_id, actor_name, type, message, amount, created_at) VALUES ($1, $2, $3, $4, 'contribution', $5, $6::float8, $7::timestamptz)",
        "parameters": ["$GENERATOR.KSUID", "$PAYLOAD.circle_id", "$PROTECTED.id", "$PROTECTED.name", "dropped their contribution", "amt", "$DATETIME"]
      }
    },
    {
      "id": 5,
      "mode": "QUERY",
      "depends_on": [
        {
          "resource_id": "self",
          "action_ids": [1],
          "extract_response_for": [{ "extract": "contribution_amount", "for": "amt" }]
        }
      ],
      "sql_query": {
        "query": "SELECT id AS circle_id, name, pot_balance, current_cycle, seats, $2 AS actor_name, $3::float8 AS amount FROM circles WHERE id = $1",
        "parameters": ["$PAYLOAD.circle_id", "$PROTECTED.name", "amt"]
      },
      "main_returnable": true,
      "returnables": ["circle_id", "name", "pot_balance", "current_cycle", "seats", "actor_name", "amount"],
      "broadcast_websocket_message": {
        "broadcast_type": "ALL",
        "action": "contribution_made"
      }
    }
  ]
}
