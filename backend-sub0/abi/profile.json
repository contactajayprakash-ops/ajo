{
  "id": "ajo-profile-01",
  "resource": "profile",
  "tokenize": {
    "type": "JWT",
    "algorithm": "HS256",
    "encryption_key": "$ENV.JWT_SECRET_KEY"
  },
  "protected": {
    "provide_as": "x-access-token",
    "extract_claims": ["id"]
  },
  "actionables": [
    {
      "id": 1,
      "mode": "QUERY",
      "sql_query": {
        "query": "SELECT id, name, email, phone, reliability_score, created_at::text AS created_at FROM users WHERE id = $1 AND deleted_at IS NULL",
        "parameters": ["$PROTECTED.id"]
      },
      "returnables": ["id", "name", "email", "phone", "reliability_score", "created_at"]
    }
  ]
}
