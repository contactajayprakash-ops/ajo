{
  "id": "ajo-activate-circle-01",
  "resource": "activate-circle",
  "tokenize": {
    "type": "JWT",
    "algorithm": "HS256",
    "encryption_key": "$ENV.JWT_SECRET_KEY"
  },
  "protected": {
    "provide_as": "x-access-token",
    "extract_claims": ["id", "name"]
  },
  "actionables": [
    {
      "id": 1,
      "mode": "QUERY",
      "sql_query": {
        "query": "UPDATE circles SET status = 'active', updated_at = $1::timestamptz WHERE id = $2 AND creator_id = $3 AND status = 'forming' RETURNING id AS circle_id, name, status, current_cycle, pot_balance, seats",
        "parameters": ["$DATETIME", "$PAYLOAD.circle_id", "$PROTECTED.id"]
      },
      "must_return_value": true,
      "returnables": ["circle_id", "name", "status", "current_cycle", "pot_balance", "seats"]
    },
    {
      "id": 2,
      "mode": "QUERY",
      "sql_query": {
        "query": "INSERT INTO activities (id, circle_id, user_id, actor_name, type, message, created_at) VALUES ($1, $2, $3, $4, 'circle_activated', $5, $6::timestamptz)",
        "parameters": ["$GENERATOR.KSUID", "$PAYLOAD.circle_id", "$PROTECTED.id", "$PROTECTED.name", "started the first cycle", "$DATETIME"]
      }
    },
    {
      "id": 3,
      "mode": "QUERY",
      "sql_query": {
        "query": "SELECT id AS circle_id, name, status FROM circles WHERE id = $1",
        "parameters": ["$PAYLOAD.circle_id"]
      },
      "returnables": ["circle_id", "name", "status"],
      "broadcast_websocket_message": {
        "broadcast_type": "ALL",
        "action": "circle_activated"
      }
    }
  ]
}
