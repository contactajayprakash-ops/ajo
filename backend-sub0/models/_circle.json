{
  "id": {
    "type": "String",
    "primary_key": true,
    "max_length": 255
  },
  "name": {
    "type": "String",
    "max_length": 255,
    "fts": true,
    "indexable": true
  },
  "description": {
    "type": "String",
    "max_length": 1000,
    "optional": true
  },
  "creator_id": {
    "type": "String",
    "foreign_key": {
      "of": "_user",
      "key": "id"
    }
  },
  "contribution_amount": {
    "type": "Float"
  },
  "currency": {
    "type": "String",
    "max_length": 8
  },
  "frequency": {
    "type": "String",
    "max_length": 16
  },
  "seats": {
    "type": "Number"
  },
  "current_cycle": {
    "type": "Number"
  },
  "pot_balance": {
    "type": "Float"
  },
  "status": {
    "type": "String",
    "max_length": 16
  },
  "invite_code": {
    "type": "String",
    "max_length": 32,
    "indexable": true
  },
  "created_at": {
    "type": "DateTime"
  },
  "updated_at": {
    "type": "DateTime"
  },
  "deleted_at": {
    "type": "DateTime",
    "optional": true
  }
}
