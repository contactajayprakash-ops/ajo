# Secrets the Sub0 app reads via $ENV.* accessors.
# Set these in the Sub0 dashboard (App -> Environment), not in git.

# Signs and verifies JWTs issued by sign-up / sign-in.
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Extra salt mixed into bcrypt password hashing.
PASSWORD_SALT=change-me-too

# Turn on the websocket layer (required for the live pot).
ALLOW_WEBSOCKET_CONNECTIONS=true

# We connect clients with ?uid=<userId>; leave uid optional so an
# unauthenticated landing page can still open a read-only socket.
FORCE_WEBSOCKET_WITH_UID=false
